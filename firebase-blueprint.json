{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "colaborador", "aluno", "professor"] },
        "primeiro_acesso": { "type": "boolean" },
        "ativo": { "type": "boolean" },
        "status": { "type": "string", "enum": ["ativo", "inativo"] },
        "checkinsTotal": { "type": "number" },
        "treinosConcluidos": { "type": "number" },
        "lastWorkoutFinish": { "type": "string", "format": "date-time" },
        "streak": { "type": "number" },
        "lastCheckin": { "type": "string", "format": "date-time" },
        "fcmToken": { "type": "string" }
      },
      "required": ["name", "cpf", "role", "primeiro_acesso"]
    },
    "WorkoutRecord": {
      "title": "Workout Record",
      "description": "Prescribed exercise routine for a student by a teacher with five divisions (A-E).",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "title": { "type": "string" },
        "divisions": {
          "type": "object",
          "properties": {
            "A": { "type": "array", "items": { "$ref": "Exercise" } },
            "B": { "type": "array", "items": { "$ref": "Exercise" } },
            "C": { "type": "array", "items": { "$ref": "Exercise" } },
            "D": { "type": "array", "items": { "$ref": "Exercise" } },
            "E": { "type": "array", "items": { "$ref": "Exercise" } }
          }
        },
        "divisionNames": {
          "type": "object",
          "properties": {
            "A": { "type": "string" },
            "B": { "type": "string" },
            "C": { "type": "string" },
            "D": { "type": "string" },
            "E": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "teacherId", "divisions"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Single exercise detail within a workout division.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "string" },
        "reps": { "type": "string" },
        "load": { "type": "string" },
        "rest": { "type": "string" },
        "order": { "type": "number" },
        "observation": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "name", "sets", "reps"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of student activities like finishing a workout for teacher feedback.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["workout_finish"] },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "teacherId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "message": { "type": "string" },
        "effort": { "type": "number" }
      },
      "required": ["type", "studentId", "teacherId", "timestamp"]
    },
    "Checkin": {
      "title": "Checkin",
      "description": "Daily check-in record for ranking.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled consultation or physical evaluation for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "services": { "type": "array", "items": { "type": "string", "enum": ["Avaliação Física", "Consulta Nutricional"] } },
        "date": { "type": "string", "format": "date-time" },
        "observation": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["Pago", "Pendente"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "services", "date", "paymentStatus", "createdBy"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of all users."
    },
    "workouts": {
      "schema": "Workout",
      "description": "Collection of workout routines keyed by studentId."
    },
    "checkins": {
      "schema": "Checkin",
      "description": "Log of daily check-ins."
    },
    "treinos": {
      "schema": "WorkoutRecord",
      "description": "Collection of student workouts prescribed by teachers."
    },
    "agendamentos": {
      "schema": "Appointment",
      "description": "Scheduled appointments (consultations and evaluations)."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Activity logs for real-time teacher feedback."
    }
  }
}
